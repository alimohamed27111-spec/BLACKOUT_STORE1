<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BLACK OUT — Premium Streetwear</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:ital@1&display=swap" rel="stylesheet"/>
<style>
  :root {
    --black: #080808;
    --charcoal: #141414;
    --dark: #1c1c1c;
    --mid: #2a2a2a;
    --border: #333;
    --accent: #c8a96e;
    --accent-light: #e8c98e;
    --white: #f5f5f5;
    --muted: #888;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    overflow-x: hidden;
  }
  #loader {
    position:fixed; inset:0; background:var(--black);
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    z-index:9999; transition: opacity 0.6s ease;
  }
  #loader .loader-brand {
    font-family:'Bebas Neue', sans-serif;
    font-size:clamp(3rem,10vw,7rem);
    letter-spacing:0.2em;
    color:var(--white);
    animation: fadeInUp 0.8s ease forwards;
  }
  #loader .loader-bar {
    width:200px; height:1px;
    background:var(--border);
    margin-top:2rem; overflow:hidden;
  }
  #loader .loader-progress {
    height:100%; width:0;
    background:var(--accent);
    animation: loadProgress 1.8s ease forwards;
  }
  @keyframes loadProgress { to { width:100%; } }
  @keyframes fadeInUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
  @keyframes slideInLeft { from { transform:translateX(-100%); } to { transform:translateX(0); } }
  @keyframes toastIn { from { transform:translateY(100px); opacity:0; } to { transform:translateY(0); opacity:1; } }
  @keyframes toastOut { from { transform:translateY(0); opacity:1; } to { transform:translateY(100px); opacity:0; } }
  @keyframes pulse { 0%,100% { transform:scale(1); } 50% { transform:scale(1.05); } }

  .reveal { opacity:0; transform:translateY(40px); transition:opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }

  #header {
    position:fixed; top:0; left:0; right:0; z-index:1000;
    background:rgba(8,8,8,0.95);
    backdrop-filter:blur(20px);
    border-bottom:1px solid var(--border);
    transition:all 0.3s ease;
  }
  #header.scrolled { background:rgba(8,8,8,0.98); }
  .nav-link {
    font-size:0.75rem; font-weight:600; letter-spacing:0.12em;
    text-transform:uppercase; color:var(--muted);
    transition:color 0.3s ease; cursor:pointer; padding:0.25rem 0;
    position:relative;
  }
  .nav-link::after {
    content:''; position:absolute; bottom:-2px; left:0; right:0;
    height:1px; background:var(--accent); transform:scaleX(0);
    transition:transform 0.3s ease;
  }
  .nav-link:hover { color:var(--white); }
  .nav-link:hover::after { transform:scaleX(1); }

  .cart-badge {
    position:absolute; top:-8px; right:-10px;
    background:var(--accent); color:var(--black);
    font-size:0.65rem; font-weight:700;
    width:18px; height:18px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    animation: pulse 2s infinite;
  }

  #hero {
    min-height:100vh; position:relative;
    display:flex; align-items:center; justify-content:center;
    overflow:hidden;
    background: linear-gradient(135deg, #080808 0%, #141414 50%, #1a1209 100%);
  }
  #hero::before {
    content:''; position:absolute; inset:0;
    background: radial-gradient(ellipse at 30% 60%, rgba(200,169,110,0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 20%, rgba(200,169,110,0.05) 0%, transparent 50%);
  }
  .hero-grid {
    position:absolute; inset:0; opacity:0.04;
    background-image: linear-gradient(var(--border) 1px, transparent 1px),
                      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size:60px 60px;
  }
  .hero-title {
    font-family:'Bebas Neue', sans-serif;
    font-size:clamp(5rem,18vw,16rem);
    line-height:0.85; letter-spacing:0.05em;
    color:var(--white);
    position:relative;
  }
  .hero-title span { color:var(--accent); }
  .hero-subtitle {
    font-size:clamp(0.65rem,1.5vw,0.85rem);
    letter-spacing:0.4em; text-transform:uppercase;
    color:var(--muted); font-weight:400;
  }
  .btn-primary {
    background:var(--accent); color:var(--black);
    font-size:0.7rem; font-weight:700; letter-spacing:0.2em;
    text-transform:uppercase; padding:1rem 2.5rem;
    border:none; cursor:pointer;
    transition:all 0.3s ease; position:relative; overflow:hidden;
  }
  .btn-primary::before {
    content:''; position:absolute; inset:0;
    background:var(--white); transform:translateX(-100%);
    transition:transform 0.3s ease;
  }
  .btn-primary:hover::before { transform:translateX(0); }
  .btn-primary span { position:relative; z-index:1; }
  .btn-primary:hover { color:var(--black); }
  .btn-outline {
    background:transparent; color:var(--white);
    font-size:0.7rem; font-weight:600; letter-spacing:0.15em;
    text-transform:uppercase; padding:0.75rem 2rem;
    border:1px solid var(--border); cursor:pointer;
    transition:all 0.3s ease;
  }
  .btn-outline:hover { border-color:var(--accent); color:var(--accent); }

  .category-card {
    position:relative; overflow:hidden; cursor:pointer;
    aspect-ratio:3/4; background:var(--dark);
    transition:transform 0.4s ease;
  }
  .category-card:hover { transform:translateY(-4px); }
  .category-card img { width:100%; height:100%; object-fit:cover; transition:transform 0.6s ease; }
  .category-card:hover img { transform:scale(1.05); }
  .category-card-overlay {
    position:absolute; inset:0;
    background:linear-gradient(to top, rgba(8,8,8,0.9) 0%, rgba(8,8,8,0.2) 50%, transparent 100%);
  }
  .category-card-label { position:absolute; bottom:0; left:0; right:0; padding:1.5rem; }
  .category-card-title { font-family:'Bebas Neue', sans-serif; font-size:2rem; letter-spacing:0.1em; }

  .product-card {
    background:var(--charcoal);
    border:1px solid var(--border);
    transition:all 0.4s ease; overflow:hidden;
    position:relative;
  }
  .product-card:hover { border-color:var(--accent); transform:translateY(-6px); box-shadow:0 20px 60px rgba(0,0,0,0.5); }
  .product-img-wrap { position:relative; overflow:hidden; aspect-ratio:3/4; background:var(--dark); }
  .product-img { width:100%; height:100%; object-fit:cover; transition:opacity 0.5s ease, transform 0.6s ease; position:absolute; inset:0; }
  .product-img.secondary { opacity:0; }
  .product-img.secondary { transform:scale(1.03); transition:opacity 0.5s ease; }
  .product-badge {
    position:absolute; top:12px; left:12px;
    background:var(--accent); color:var(--black);
    font-size:0.6rem; font-weight:700; letter-spacing:0.1em;
    text-transform:uppercase; padding:0.25rem 0.6rem;
  }
  .product-info { padding:1.25rem; }
  .product-name { font-size:0.85rem; font-weight:600; letter-spacing:0.05em; margin-bottom:0.5rem; }
  .product-price { font-family:'Bebas Neue', sans-serif; font-size:1.4rem; color:var(--accent); letter-spacing:0.05em; }
  .product-price-egp { font-size:0.65rem; color:var(--muted); font-weight:500; }
  .size-btn {
    font-size:0.65rem; font-weight:600; padding:0.35rem 0.5rem;
    border:1px solid var(--border); background:transparent;
    color:var(--muted); cursor:pointer; transition:all 0.2s ease;
    min-width:36px; text-align:center;
  }
  .size-btn:hover { border-color:var(--accent); color:var(--accent); }
  .size-btn.selected { background:var(--accent); color:var(--black); border-color:var(--accent); }
  .add-cart-btn {
    width:100%; padding:0.85rem; margin-top:1rem;
    background:var(--mid); color:var(--white);
    font-size:0.7rem; font-weight:700; letter-spacing:0.15em;
    text-transform:uppercase; border:none; cursor:pointer;
    transition:all 0.3s ease;
  }
  .add-cart-btn:hover { background:var(--accent); color:var(--black); }

  /* Products transition */
  #products-grid {
    transition: opacity 0.3s ease;
  }
  #products-grid.fading {
    opacity: 0;
    pointer-events: none;
  }

  /* Section title transition */
  #products-section-title {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  #products-section-title.fading {
    opacity: 0;
    transform: translateY(-8px);
  }

  #cart-overlay {
    position:fixed; inset:0; background:rgba(0,0,0,0.7);
    z-index:2000; opacity:0; pointer-events:none;
    transition:opacity 0.3s ease; backdrop-filter:blur(4px);
  }
  #cart-overlay.open { opacity:1; pointer-events:all; }
  #cart-drawer {
    position:fixed; top:0; right:0; bottom:0;
    width:min(420px, 100vw);
    background:var(--charcoal);
    border-left:1px solid var(--border);
    z-index:2001;
    transform:translateX(100%);
    transition:transform 0.4s cubic-bezier(0.16,1,0.3,1);
    display:flex; flex-direction:column; overflow:hidden;
  }
  #cart-drawer.open { transform:translateX(0); }
  .cart-header { padding:1.5rem; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
  .cart-items { flex:1; overflow-y:auto; padding:1rem; scrollbar-width:thin; scrollbar-color:var(--border) transparent; }
  .cart-item { display:flex; gap:1rem; padding:1rem 0; border-bottom:1px solid var(--border); }
  .cart-item-img { width:72px; height:90px; object-fit:cover; background:var(--dark); flex-shrink:0; }
  .cart-item-name { font-size:0.8rem; font-weight:600; margin-bottom:0.25rem; }
  .cart-item-size { font-size:0.7rem; color:var(--muted); margin-bottom:0.5rem; }
  .cart-item-price { font-family:'Bebas Neue', sans-serif; font-size:1.1rem; color:var(--accent); }
  .qty-btn { width:28px; height:28px; background:var(--mid); border:none; color:var(--white); cursor:pointer; font-size:1rem; transition:background 0.2s; }
  .qty-btn:hover { background:var(--accent); color:var(--black); }
  .qty-display { width:32px; text-align:center; font-size:0.85rem; font-weight:600; }
  .cart-footer { padding:1.5rem; border-top:1px solid var(--border); background:var(--dark); }
  .total-row { display:flex; justify-content:space-between; font-size:0.8rem; color:var(--muted); margin-bottom:0.5rem; }
  .grand-total { display:flex; justify-content:space-between; font-family:'Bebas Neue', sans-serif; font-size:1.6rem; color:var(--white); margin:1rem 0; }
  .grand-total span:last-child { color:var(--accent); }
  .empty-cart { display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; gap:1rem; color:var(--muted); }
  .empty-cart svg { opacity:0.3; }
  .empty-cart p { font-size:0.85rem; letter-spacing:0.05em; }

  #checkout { background:var(--charcoal); border-top:1px solid var(--border); }
  .input-field {
    width:100%; background:var(--dark); border:1px solid var(--border);
    color:var(--white); padding:0.9rem 1rem; font-size:0.85rem;
    font-family:'Montserrat', sans-serif;
    transition:border-color 0.3s ease; outline:none;
  }
  .input-field:focus { border-color:var(--accent); }
  .input-field::placeholder { color:var(--muted); }
  label.form-label { font-size:0.7rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); display:block; margin-bottom:0.5rem; }
  .payment-block {
    background:var(--dark); border:1px solid var(--accent);
    padding:1.5rem; text-align:center; border-left-width:4px;
  }
  .payment-block p { font-size:0.9rem; line-height:1.8; color:var(--white); direction:rtl; }
  .payment-block strong { color:var(--accent); font-size:1.1rem; }
  .file-upload-area {
    border:2px dashed var(--border); padding:2rem;
    text-align:center; cursor:pointer;
    transition:border-color 0.3s ease, background 0.3s ease; position:relative;
  }
  .file-upload-area:hover { border-color:var(--accent); }
  .file-upload-area input[type="file"] { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%; }
  .file-preview-wrap {
    margin-top:1rem; display:none;
    flex-direction:column; align-items:center; gap:0.75rem;
  }
  .file-preview-wrap.visible { display:flex; }
  .file-preview-img {
    max-width:200px; max-height:200px; object-fit:contain;
    border:1px solid var(--accent); padding:4px;
  }
  .file-preview-name {
    font-size:0.75rem; color:var(--accent); font-weight:600;
  }

  #modal-overlay {
    position:fixed; inset:0; background:rgba(0,0,0,0.8);
    z-index:9000; display:flex; align-items:center; justify-content:center;
    opacity:0; pointer-events:none; transition:opacity 0.3s ease;
    backdrop-filter:blur(8px);
  }
  #modal-overlay.open { opacity:1; pointer-events:all; }
  #modal-box {
    background:var(--charcoal); border:1px solid var(--accent);
    max-width:480px; width:90%; padding:2.5rem;
    transform:translateY(30px); transition:transform 0.4s ease;
  }
  #modal-overlay.open #modal-box { transform:translateY(0); }
  #modal-box p { direction:rtl; line-height:1.9; font-size:0.95rem; color:var(--white); }
  #modal-box strong { color:var(--accent); }

  #toast-container { position:fixed; bottom:2rem; left:50%; transform:translateX(-50%); z-index:9999; display:flex; flex-direction:column; gap:0.5rem; align-items:center; pointer-events:none; }
  .toast {
    background:var(--dark); border:1px solid var(--border);
    color:var(--white); padding:0.85rem 1.5rem;
    font-size:0.8rem; font-weight:500; letter-spacing:0.05em;
    animation: toastIn 0.4s ease forwards;
    white-space:nowrap; max-width:90vw;
  }
  .toast.error { border-color:#ef4444; color:#ef4444; }
  .toast.success { border-color:var(--accent); color:var(--accent); }
  .toast.hiding { animation: toastOut 0.4s ease forwards; }

  #mobile-menu {
    position:fixed; top:0; left:0; right:0; bottom:0;
    background:var(--black); z-index:1500;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:2rem;
    transform:translateX(-100%);
    transition:transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  #mobile-menu.open { transform:translateX(0); }
  .mobile-nav-link {
    font-family:'Bebas Neue', sans-serif;
    font-size:3rem; letter-spacing:0.1em;
    color:var(--muted); transition:color 0.3s ease; cursor:pointer;
  }
  .mobile-nav-link:hover { color:var(--accent); }

  /* Size Guide — image only */
  #size-guide { background:var(--dark); }
  .size-guide-container {
    max-width:700px; margin:0 auto; text-align:center;
  }
  .size-guide-img-wrap {
    position:relative; overflow:hidden;
    border:1px solid var(--border);
    background:var(--charcoal);
  }
  .size-guide-img-wrap img {
    width:100%; display:block;
    transition:transform 0.6s ease;
  }
  .size-guide-img-wrap:hover img { transform:scale(1.02); }

  .section-label { font-size:0.7rem; letter-spacing:0.4em; text-transform:uppercase; color:var(--accent); margin-bottom:0.75rem; }
  .section-title { font-family:'Bebas Neue', sans-serif; font-size:clamp(2.5rem,6vw,5rem); letter-spacing:0.05em; line-height:1; }

  footer { background:var(--black); border-top:1px solid var(--border); }
  .social-icon { width:40px; height:40px; border:1px solid var(--border); display:flex; align-items:center; justify-content:center; transition:all 0.3s ease; cursor:pointer; }
  .social-icon:hover { border-color:var(--accent); color:var(--accent); }

  ::-webkit-scrollbar { width:4px; }
  ::-webkit-scrollbar-track { background:var(--black); }
  ::-webkit-scrollbar-thumb { background:var(--border); }

  .filter-btn { font-size:0.7rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; padding:0.5rem 1.25rem; border:1px solid var(--border); background:transparent; color:var(--muted); cursor:pointer; transition:all 0.2s ease; }
  .filter-btn:hover, .filter-btn.active { background:var(--accent); color:var(--black); border-color:var(--accent); }

  #floating-cart {
    position:fixed; bottom:2rem; right:2rem; z-index:500;
    background:var(--accent); color:var(--black);
    width:56px; height:56px; border-radius:0;
    display:flex; align-items:center; justify-content:center;
    cursor:pointer; border:none;
    box-shadow:0 8px 30px rgba(200,169,110,0.4);
    transition:all 0.3s ease;
  }
  #floating-cart:hover { transform:scale(1.1); background:var(--accent-light); }
  #floating-cart .fc-badge {
    position:absolute; top:-6px; right:-6px;
    background:var(--black); color:var(--accent);
    width:20px; height:20px; border-radius:50%;
    font-size:0.65rem; font-weight:700;
    display:flex; align-items:center; justify-content:center;
  }

  /* Mobile responsiveness improvements */
  @media (max-width: 640px) {
    .btn-primary, .btn-outline { padding:0.85rem 1.5rem; }
    .product-info { padding:1rem; }
    #cart-drawer { width:100vw; }
    .size-btn { min-width:32px; padding:0.3rem 0.4rem; font-size:0.6rem; }
  }
</style>
</head>
<body>

<!-- LOADING SCREEN -->
<div id="loader">
  <div class="loader-brand">BLACK OUT</div>
  <div style="font-size:0.65rem;letter-spacing:0.4em;color:var(--muted);margin-top:0.75rem;text-transform:uppercase;">Premium Streetwear</div>
  <div class="loader-bar"><div class="loader-progress"></div></div>
</div>

<!-- TOAST CONTAINER -->
<div id="toast-container"></div>

<!-- MODAL -->
<div id="modal-overlay">
  <div id="modal-box">
    <div style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:0.1em;margin-bottom:1.25rem;color:var(--accent)">تأكيد الطلب</div>
    <p id="modal-content"></p>
    <div style="display:flex;gap:1rem;margin-top:2rem;">
      <button id="modal-ok" class="btn-primary" style="flex:1;"><span>موافق — فتح واتساب</span></button>
      <button id="modal-cancel" class="btn-outline" style="flex:0 0 auto;" onclick="closeModal()">إلغاء</button>
    </div>
  </div>
</div>

<!-- MOBILE MENU -->
<div id="mobile-menu">
  <button style="position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;color:var(--white);font-size:1.5rem;cursor:pointer;" onclick="toggleMenu()">✕</button>
  <div class="mobile-nav-link" onclick="filterProducts('all');toggleMenu();scrollTo('#products')">All</div>
  <div class="mobile-nav-link" onclick="filterProducts('pants');toggleMenu();scrollTo('#products')">Pants</div>
  <div class="mobile-nav-link" onclick="filterProducts('shorts');toggleMenu();scrollTo('#products')">Shorts</div>
  <div class="mobile-nav-link" onclick="filterProducts('suits');toggleMenu();scrollTo('#products')">Suits</div>
  <div class="mobile-nav-link" onclick="filterProducts('tshirts');toggleMenu();scrollTo('#products')">T-Shirts</div>
  <div class="mobile-nav-link" onclick="openCart();toggleMenu()">Cart</div>
</div>

<!-- HEADER -->
<header id="header">
  <div style="max-width:1400px;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:70px;">
    <div style="display:flex;align-items:center;gap:0.75rem;cursor:pointer;" onclick="scrollTo('#hero')">
      <div style="width:36px;height:36px;background:var(--accent);display:flex;align-items:center;justify-content:center;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="black"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
      </div>
      <span style="font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:0.1em;color:var(--white);">BLACK OUT</span>
    </div>
    <nav style="display:flex;gap:2rem;align-items:center;" class="hidden md:flex">
      <span class="nav-link" onclick="filterProducts('pants');scrollTo('#products')">Pants</span>
      <span class="nav-link" onclick="filterProducts('shorts');scrollTo('#products')">Shorts</span>
      <span class="nav-link" onclick="filterProducts('suits');scrollTo('#products')">Suits</span>
      <span class="nav-link" onclick="filterProducts('tshirts');scrollTo('#products')">T-Shirts</span>
      <span class="nav-link" onclick="scrollTo('#size-guide')">Size Guide</span>
      <button onclick="openCart()" style="position:relative;background:none;border:none;cursor:pointer;color:var(--white);display:flex;align-items:center;gap:0.5rem;" class="nav-link">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Cart
        <span class="cart-badge" id="cart-badge">0</span>
      </button>
    </nav>
    <button class="md:hidden" onclick="toggleMenu()" style="background:none;border:none;color:var(--white);cursor:pointer;">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
    </button>
  </div>
</header>

<!-- HERO -->
<section id="hero">
