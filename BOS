  { id:22, name:"Black Polo Shirt", category:"tshirts", price:680, img1:"https://i.ibb.co/mVvXGmDb/IMG-5723.jpg" },
  { id:23, name:"Blue Polo Shirt", category:"tshirts", price:680, img1:"https://i.ibb.co/jvsgFvd9/IMG-5724.jpg" },
  { id:24, name:"White Camo Tee", category:"tshirts", price:680, img1:"https://i.ibb.co/hJ7n1YyP/IMG-5730.jpg" }
];
const categoryTitles = {
  all: 'Latest Drops',
  pants: 'Pants Collection',
  shorts: 'Shorts Collection',
  suits: 'Suits Collection',
  tshirts: 'T-Shirts Collection'
};

let cart = [];
try { cart = JSON.parse(localStorage.getItem('bo_cart') || '[]'); } catch(e) { cart = []; }
let selectedFile = null;
const selectedSizes = {};

function saveCart() { try { localStorage.setItem('bo_cart', JSON.stringify(cart)); } catch(e) {} }
function getCartTotal() { return cart.reduce((s, i) => s + i.price * i.qty, 0); }

function updateCartBadges() {
  const count = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('cart-badge').textContent = count;
  document.getElementById('fc-badge').textContent = count;
  document.getElementById('cart-item-count').textContent = count + ' item' + (count !== 1 ? 's' : '');
}

function renderCart() {
  const list = document.getElementById('cart-items-list');
  const footer = document.getElementById('cart-footer');
  if (cart.length === 0) {
    list.innerHTML = `<div class="empty-cart">
      <svg width="60" height="60" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <p>Your cart is empty</p>
      <button class="btn-outline" onclick="closeCart()" style="font-size:0.7rem;">Continue Shopping</button>
    </div>`;
    footer.style.display = 'none';
    return;
  }
  footer.style.display = 'block';
  list.innerHTML = cart.map(item => `
    <div class="cart-item">
      <img class="cart-item-img" src="${item.img}" alt="${item.name}" onerror="this.src='https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=200&q=80'"/>
      <div style="flex:1;min-width:0;">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-size">Size: ${item.size}</div>
        <div class="cart-item-price">${(item.price * item.qty).toLocaleString()} EGP</div>
        <div style="display:flex;align-items:center;gap:0.25rem;margin-top:0.5rem;">
          <button class="qty-btn" onclick="changeQty(${item.id},'${item.size}',-1)">−</button>
          <span class="qty-display">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty(${item.id},'${item.size}',1)">+</button>
          <button onclick="removeItem(${item.id},'${item.size}')" style="margin-left:auto;background:none;border:none;color:var(--muted);cursor:pointer;font-size:0.75rem;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--muted)'">Remove</button>
        </div>
      </div>
    </div>
  `).join('');
  const sub = getCartTotal();
  document.getElementById('cart-subtotal').textContent = sub.toLocaleString() + ' EGP';
  document.getElementById('cart-grand-total').textContent = (sub + 100).toLocaleString() + ' EGP';
  renderOrderSummary();
}

function renderOrderSummary() {
  const items = document.getElementById('order-summary-items');
  const sub = getCartTotal();
  if (items) {
    items.innerHTML = cart.map(i => `
      <div style="display:flex;justify-content:space-between;font-size:0.8rem;padding:0.5rem 0;border-bottom:1px solid var(--border);">
        <span>${i.name} (${i.size}) x${i.qty}</span>
        <span>${(i.price * i.qty).toLocaleString()} EGP</span>
      </div>
    `).join('') || '<div style="color:var(--muted);">No items</div>';
    document.getElementById('co-subtotal').textContent = sub.toLocaleString() + ' EGP';
    document.getElementById('co-grand-total').textContent = (sub + 100).toLocaleString() + ' EGP';
  }
}

function changeQty(id, size, delta) {
  const idx = cart.findIndex(i => i.id === id && i.size === size);
  if (idx === -1) return;
  cart[idx].qty += delta;
  if (cart[idx].qty <= 0) cart.splice(idx, 1);
  saveCart(); renderCart(); updateCartBadges();
}

function removeItem(id, size) {
  cart = cart.filter(i => !(i.id === id && i.size === size));
  saveCart(); renderCart(); updateCartBadges();
}

function addToCart(productId, size, name, price, img) {
  const existing = cart.find(i => i.id === productId && i.size === size);
  if (existing) { existing.qty++; }
  else { cart.push({ id: productId, name, price, size, qty: 1, img }); }
  saveCart(); renderCart(); updateCartBadges();
  showToast('Added to cart: ' + name + ' (' + size + ')', 'success');
}

function renderProducts(filter) {
  const grid = document.getElementById('products-grid');
  const titleEl = document.getElementById('products-section-title');
  grid.classList.add('fading');
  titleEl.classList.add('fading');
  setTimeout(() => {
    titleEl.textContent = categoryTitles[filter] || 'Latest Drops';
    const filtered = filter === 'all' ? products : products.filter(p => p.category === filter);
    grid.innerHTML = filtered.map(p => `
      <div class="product-card">
        <div class="product-img-wrap">
          <img class="product-img primary" src="${p.img1}" alt="${p.name}" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=500&q=80'"/>
          
        </div>
        <div class="product-info">
          <div class="product-name">${p.name}</div>
          <div class="product-price">${p.price.toLocaleString()} <span class="product-price-egp">EGP</span></div>
          <div style="margin-top:1rem;">
            <div style="font-size:0.65rem;letter-spacing:0.1em;color:var(--muted);text-transform:uppercase;margin-bottom:0.5rem;">Select Size</div>
            <div style="display:flex;gap:0.35rem;flex-wrap:wrap;" id="sizes-${p.id}">
              ${['S','M','L','XL','XXL'].map(s => `<button class="size-btn" onclick="selectSize(${p.id},'${s}')" id="sz-${p.id}-${s}">${s}</button>`).join('')}
            </div>
          </div>
          <button class="add-cart-btn" onclick="handleAddToCart(${p.id})">Add to Cart</button>
        </div>
      </div>
    `).join('');
    filtered.forEach(p => {
      if (selectedSizes[p.id]) {
        const btn = document.getElementById(`sz-${p.id}-${selectedSizes[p.id]}`);
        if (btn) btn.className = 'size-btn selected';
      }
    });
    grid.classList.remove('fading');
    titleEl.classList.remove('fading');
  }, 280);
}

function selectSize(productId, size) {
  selectedSizes[productId] = size;
  ['S','M','L','XL','XXL'].forEach(s => {
    const btn = document.getElementById(`sz-${productId}-${s}`);
    if (btn) btn.className = 'size-btn' + (s === size ? ' selected' : '');
  });
}

function handleAddToCart(productId) {
  const size = selectedSizes[productId];
  if (!size) { showToast('Please select a size first.', 'error'); return; }
  const p = products.find(x => x.id === productId);
  if (!p) return;
  addToCart(p.id, size, p.name, p.price, p.img1);
}

function filterProducts(cat) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.cat === cat));
  renderProducts(cat);
}

function openCart() {
  document.getElementById('cart-overlay').classList.add('open');
  document.getElementById('cart-drawer').classList.add('open');
  document.body.style.overflow = 'hidden';
  renderCart();
}

function closeCart() {
  document.getElementById('cart-overlay').classList.remove('open');
  document.getElementById('cart-drawer').classList.remove('open');
  document.body.style.overflow = '';
}

function toggleMenu() { document.getElementById('mobile-menu').classList.toggle('open'); }
function scrollTo(selector) { const el = document.querySelector(selector); if (el) el.scrollIntoView({ behavior:'smooth', block:'start' }); }

function showToast(msg, type = 'default') {
  const container = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = 'toast ' + type;
  t.textContent = msg;
  container.appendChild(t);
  setTimeout(() => { t.classList.add('hiding'); setTimeout(() => t.remove(), 400); }, 3000);
}

function handleFileUpload(e) {
  const file = e.target.files[0];
  if (!file) return;
  selectedFile = file;
  const reader = new FileReader();
  reader.onload = (ev) => {
    const previewWrap = document.getElementById('file-preview-wrap');
    const previewImg = document.getElementById('file-preview-img');
    const previewName = document.getElementById('file-preview-name');
    previewImg.src = ev.target.result;
    previewName.textContent = '✓ ' + file.name;
    previewWrap.classList.add('visible');
  };
  reader.readAsDataURL(file);
  document.getElementById('upload-area').style.borderColor = 'var(--accent)';
  document.getElementById('upload-area').style.background = 'rgba(200,169,110,0.04)';
  showToast('Screenshot uploaded: ' + file.name, 'success');
}

function openModal(content, onOk) {
  document.getElementById('modal-content').innerHTML = content;
  document.getElementById('modal-overlay').classList.add('open');
  document.getElementById('modal-ok').onclick = () => { closeModal(); onOk(); };
}

function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); }

function placeOrder() {
  const name = document.getElementById('full-name').value.trim();
  const phone = document.getElementById('phone').value.trim();
  const address = document.getElementById('address').value.trim();
  const depositNum = document.getElementById('deposit-number').value.trim();
  if (cart.length === 0) { showToast('Your cart is empty.', 'error'); openCart(); return; }
  if (!name) { showToast('Full name required.', 'error'); return; }
  if (!phone) { showToast('Phone number required.', 'error'); return; }
  if (!address) { showToast('Address required.', 'error'); return; }
  if (!depositNum) { showToast('Deposit transfer number required.', 'error'); return; }
  if (!selectedFile) { showToast('Please upload deposit screenshot.', 'error'); return; }
  const sub = getCartTotal();
  const grand = sub + 100;
  const itemsText = cart.map(i => `• ${i.name} | Size: ${i.size} | Qty: ${i.qty} | ${(i.price * i.qty).toLocaleString()} EGP`).join('\n');
  const waMsg = encodeURIComponent(
    `🖤 BLACK OUT — New Order\n━━━━━━━━━━━━━━━━━━━━━━\n👤 Customer: ${name}\n📞 Phone: ${phone}\n📍 Address: ${address}\n💳 Deposit Transfer Number: ${depositNum}\n━━━━━━━━━━━━━━━━━━━━━━\n🛍 Ordered Items:\n${itemsText}\n━━━━━━━━━━━━━━━━━━━━━━\n💰 Subtotal: ${sub.toLocaleString()} EGP\n🚚 Shipping: 100 EGP\n✅ Grand Total: ${grand.toLocaleString()} EGP\n━━━━━━━━━━━━━━━━━━━━━━\n📎 Deposit Screenshot attached in this chat`
  );
  const modalText = `لإرسال الطلب بنجاح:<br/><br/>سيتم فتح واتساب الآن،<br/>برجاء إرسال رسالة البيانات التلقائية،<br/>ثم قم بإرفاق صورة تحويل المحفظة يدوياً<br/><strong>(المودعة على رقم 01147477039)</strong><br/>في الشات مباشرة لتأكيد الأوردر.`;
  openModal(modalText, () => {
    window.open(`https://wa.me/201273144003?text=${waMsg}`, '_blank');
    showToast('Order sent via WhatsApp!', 'success');
  });
}

function initScrollReveal() {
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
}

window.addEventListener('scroll', () => {
  document.getElementById('header').classList.toggle('scrolled', window.scrollY > 50);
});

window.addEventListener('load', () => {
  renderProducts('all');
  updateCartBadges();
  renderCart();
  renderOrderSummary();
  setTimeout(() => {
    const loader = document.getElementById('loader');
    loader.style.opacity = '0';
    loader.style.pointerEvents = 'none';
    setTimeout(() => loader.remove(), 600);
    initScrollReveal();
  }, 2000);
});
</script>
</body>
</html>
